{
  "type": "iska_utils:command_item",
  "overwritable": true,
  "items": [
    {
      "id": "iska_utils-world_init",
      "creative_tab": false,
      "stack_size": 1,
      "is_foil": false,
      "stages_logic": "DEF_AND",
      "cooldown": 10,
      "stages": [
          {"stage_type": "world", "stage": "initializing", "is": false},
          {"stage_type": "world", "stage": "initialized", "is": false},
          {"stage_type": "world", "stage": "initialized", "is": true}
      ],
      "do": [
        {
          "onTick": [
            {"if": [
                {"conditions":[0,1]},
                {"execute": "iska_utils_stage add world initializing true"},
                {"message": {"target":"@a","color":"#FF0000","in":"action_bar","text":"message.iska_utils.world_init.stand_still"}},
                {"message": {"target":"@a","color":"#FF0000","in":"action_bar","text":"message.iska_utils.world_init.initializing"}},
                {"delay": 160},
                {"execute": "kubejs reload server-scripts"},
                {"execute": "reload"},
                {"delay": 20},
                {"execute": "custommachinery reload"},
                {"message": {"target":"@a","color":"#00FF00","in":"action_bar","text":"message.iska_utils.world_init.completed"}},
                {"execute": "iska_utils_stage add world initialized true"},
                {"execute": "iska_utils_stage remove world initializing true"},
                {"item": "delete_all"}
            ]},
            {"if": [
                {"conditions":[0,2]},
                {"item": "delete_all"}
            ]}
          ]
        }
      ]
    }
  ]
}
