{
  "type": "iska_utils:command_item",
  "overwritable": true,
  "items": [
    {
      "id": "iska_utils-world_init",
      "creative_tab": false,
      "stack_size": 1,
      "is_foil": false,
      "stages_logic": "DEF_AND",
      "cooldown": 10,
      "stages": [
          {"stage_type": "world", "stage": "initializing", "is": false},
          {"stage_type": "world", "stage": "initialized", "is": false},
          {"stage_type": "world", "stage": "initialized", "is": true}
      ],
      "do": [
        {
          "onTick": [
            {"if": [
                {"conditions":[0,1]},
                {"execute": "iska_utils_stage add world initializing true"},
                {"execute": "title @a times 20 100 40"},
                {"execute": "title @a subtitle {\"text\":\"please stand still and do nothing.\",\"color\":\"dark_red\"}"},
                {"execute": "title @a title {\"text\":\"World Initialization:\",\"color\":\"dark_red\"}"},
                {"delay": 160},
                {"execute": "kubejs reload server-scripts"},
                {"execute": "reload"},
                {"delay": 20},
                {"execute": "custommachinery reload"},
                {"execute": "title @a times 20 100 40"},
                {"execute": "title @a subtitle {\"text\":\"completed, apologies for the wait\",\"color\":\"dark_green\"}"},
                {"execute": "title @a title {\"text\":\"World Initialization:\",\"color\":\"dark_green\"}"},
                {"execute": "title @a times 20 100 20"},
                {"execute": "iska_utils_stage add world initialized true"},
                {"execute": "iska_utils_stage remove world initializing true"},
                {"item": "delete_all"}
            ]},
            {"if": [
                {"conditions":[0,2]},
                {"item": "delete_all"}
            ]}
          ]
        }
      ]
    }
  ]
}

